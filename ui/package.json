{
  "name": "orgasmic-ui",
  "private": true,
  "version": "0.0.7",
  "type": "module",
  "engines": {
    "node": "^18.0.0 || ^20.0.0 || >=22.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit && vite build",
    "build:bootstrap": "tsc --noEmit && vite build --config vite.bootstrap.config.ts && node -e \"const fs=require('fs'); if (fs.existsSync('bootstrap-dist/bootstrap.html')) fs.renameSync('bootstrap-dist/bootstrap.html','bootstrap-dist/index.html')\"",
    "preview": "vite preview --host 127.0.0.1",
    "dev:bootstrap": "vite --config vite.bootstrap.config.ts --host 127.0.0.1",
    "tauri": "cd .. && tauri",
    "tauri:dev": "cd .. && tauri dev --config src-tauri/tauri.conf.json",
    "tauri:build": "cd .. && tauri build --config src-tauri/tauri.conf.json",
    "tauri:bundle:mac": "cd .. && tauri build --config src-tauri/tauri.conf.json --target aarch64-apple-darwin --bundles app,dmg",
    "tauri:android:init": "cd .. && PATH=\"$HOME/.cargo/bin:$PATH\" tauri android init --config src-tauri/tauri.conf.json --config src-tauri/tauri.android.conf.json",
    "tauri:android:dev": "cd .. && PATH=\"$HOME/.cargo/bin:$PATH\" tauri android dev --config src-tauri/tauri.conf.json --config src-tauri/tauri.android.conf.json --host 10.0.2.2",
    "tauri:android:build:debug": "cd .. && PATH=\"$HOME/.cargo/bin:$PATH\" tauri android build --config src-tauri/tauri.conf.json --config src-tauri/tauri.android.conf.json --debug --target aarch64 --apk",
    "tauri:android:build": "cd .. && PATH=\"$HOME/.cargo/bin:$PATH\" tauri android build --config src-tauri/tauri.conf.json --config src-tauri/tauri.android.conf.json --target aarch64 --apk"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-router": "^1.170.7",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^7.0.29",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.16.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "roughjs": "^4.6.6",
    "shadcn": "^4.8.0",
    "shiki": "^4.3.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-devtools": "^1.167.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.0",
    "vite": "^6.3.0",
    "vitest": "^2.0.0"
  }
}
